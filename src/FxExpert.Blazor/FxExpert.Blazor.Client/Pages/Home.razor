@page "/"

 
@page "/"

<PageTitle>Home</PageTitle>

<h3>Describe Your Problem</h3>

<EditForm>
    <MudTextField @bind-Value="problemDescription" Label="Problem Description" Variant="Variant.Outlined" FullWidth="true" Multiline="true" Rows="5" />
    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SubmitProblem">Submit</MudButton>
</EditForm>

@inject HttpClient Http

@code {
    private string problemDescription = string.Empty;
    private List<Partner> partners = new();

    private async Task SubmitProblem()
    {
        var response = await Http.PostAsJsonAsync("/api/ai/partners", new { ProblemDescription = problemDescription });
        if (response.IsSuccessStatusCode)
        {
            partners = await response.Content.ReadFromJsonAsync<List<Partner>>();
            Console.WriteLine($"Retrieved {partners.Count} partners.");
        }
        else
        {
            Console.WriteLine("Failed to retrieve partners.");
        }
    }
}
